<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    android:orientation="vertical">

    <!-- 顶部搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_field"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:hint="搜索动作"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 器械筛选 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_equipment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all_equipment"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="全部"
                android:textSize="12sp"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_barbell"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="杠铃"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dumbbell"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="哑铃"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_machine"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="器械"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cable"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="绳索"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_bodyweight"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="自重"
                android:textSize="12sp" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- 左右分栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- 左侧肌群列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_muscle_groups"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="#F5F5F5" />

        <!-- 右侧动作列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_exercises"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="8dp" />

    </LinearLayout>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="已选 0 个"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="确认添加"
            android:textSize="13sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
